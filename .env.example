# Public host port for the dashboard frontend
THEDASH_PORT=8080

# GHCR owner for prebuilt images
GHCR_OWNER=mschoettli

# Image tag for prebuilt images
THEDASH_IMAGE_TAG=latest

# SQLite database path inside the backend container
DB_PATH=/data/thedash.db

# Docker polling interval in milliseconds
DOCKER_POLL_INTERVAL=5000

# System metrics polling interval in milliseconds
METRICS_POLL_INTERVAL=3000

# Optional Docker API URL for container monitoring.
# The compose files default to the included docker-socket-proxy when the
# docker-monitoring profile is enabled.
DOCKER_HOST_URL=http://dockerproxy:2375
