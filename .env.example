# Host-Port für das Dashboard
THEDASH_PORT=8080

# Pfad zur SQLite-Datenbank im Container
DB_PATH=/data/thedash.db

# Docker-Socket Polling-Intervall (ms)
DOCKER_POLL_INTERVAL=5000

# System-Metriken Polling-Intervall (ms)
METRICS_POLL_INTERVAL=3000

# App-Titel (wird im Browser-Tab angezeigt)
VITE_APP_TITLE=TheDash
